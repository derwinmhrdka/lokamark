# Copy this file to `.env.local` for local development.
# Add the same keys in Vercel → Project → Settings → Environment Variables.

AIRTABLE_API_KEY=patXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXX

SESSION_SECRET=random-long-secret-string

# Airtable `lontar_detail` fields used by the app:
# - status (single select): verified | waiting for approval | inactive
# - createdBy, updatedBy (text)
# - createdDate, updatedDate (date with time — ISO datetime, e.g. 2026-07-17T08:47:00.000Z)
# - qr (attachment): auto-filled when lontar becomes verified
